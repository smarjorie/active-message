# Este projeto NAO guarda o token de acesso da Meta como variavel de
# ambiente. O token e passado a cada chamada, direto na conversa/tool call
# (parametro "access_token"), e nunca fica salvo no servidor/Vercel.

# ID da WhatsApp Business Account (WABA) padrao (opcional -
# pode ser passado por chamada via parametro waba_id em vez de fixar aqui)
META_WABA_ID=

# Versao da Graph API (opcional, padrao v23.0)
META_API_VERSION=v23.0
